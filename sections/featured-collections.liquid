<div class="featured-collections">
  <div class="section-header">
    <h2>{{ section.settings.title | default: 'Featured Collections' }}</h2>
  </div>
  <div class="masonry-grid">
    {%- for block in section.blocks -%}
      {%- assign collection = collections[block.settings.collection] -%}
      {%- if collection != blank -%}
        <div class="collection-card" {{ block.shopify_attributes }}>
          <a href="{{ collection.url }}">
            {%- if collection.image != blank -%}
              <img src="{{ collection.image | img_url: '600x600', crop: 'center' }}" alt="{{ collection.title | escape }}">
            {%- else -%}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-image' }}
            {%- endif -%}
            <div class="collection-overlay">
              <h3 class="collection-title">{{ collection.title }}</h3>
            </div>
          </a>
        </div>
      {%- else -%}
        <div class="collection-card" {{ block.shopify_attributes }}>
          {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-image' }}
          <div class="collection-overlay">
            <h3 class="collection-title">Collection</h3>
          </div>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="collection-card">
        {{ 'collection-1' | placeholder_svg_tag: 'collection-image' }}
        <div class="collection-overlay">
          <h3 class="collection-title">Streetwear</h3>
        </div>
      </div>
      <div class="collection-card">
        {{ 'collection-2' | placeholder_svg_tag: 'collection-image' }}
        <div class="collection-overlay">
          <h3 class="collection-title">Tech Gear</h3>
        </div>
      </div>
      <div class="collection-card">
        {{ 'collection-3' | placeholder_svg_tag: 'collection-image' }}
        <div class="collection-overlay">
          <h3 class="collection-title">Accessories</h3>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Featured Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 6,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default Featured Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
