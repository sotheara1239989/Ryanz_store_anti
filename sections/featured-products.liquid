<div class="featured-products">
  <div class="section-header">
    <h2>{{ section.settings.title | default: 'Latest Drops' }}</h2>
  </div>
  <div class="product-grid">
    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection == blank -%}
      {%- assign collection = collections['all'] -%}
    {%- endif -%}
    
    {%- for product in collection.products limit: 4 -%}
      <div class="product-card">
        <a href="{{ product.url }}">
          {%- if product.featured_image != blank -%}
            <img class="product-image" src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}" alt="{{ product.title | escape }}">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'product-image' }}
          {%- endif -%}
          <h3 class="product-title">{{ product.title }}</h3>
          <div class="product-price">{{ product.price | money }}</div>
        </a>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Latest Drops"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection (Defaults to All Products)"
    }
  ],
  "presets": [
    {
      "name": "Default Featured Products"
    }
  ]
}
{% endschema %}
